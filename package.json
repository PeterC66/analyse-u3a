{
  "name": "analyse-u3a",
  "version": "0.0.8",
  "private": true,
  "type": "module",
  "description": "Local-only desktop analysis tool for u3a Beacon backup files",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite && electron .",
    "build": "tsc --noEmit && vite build && tsc -p electron/tsconfig.json",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^31.4.0",
    "electron-builder": "^25.0.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.analyse-u3a.app",
    "productName": "Analyse u3a",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": []
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "peterc66",
      "repo": "analyse-u3a",
      "releaseType": "release"
    }
  }
}

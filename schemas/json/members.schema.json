{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "beacon/members.schema.json",
  "title": "Members sheet row",
  "description": "One row per person. Couples on a joint membership get TWO rows sharing the same akey.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mkey", "mem_no", "status", "forename", "surname", "class", "enhanced_privacy"],
  "properties": {
    "mkey":              { "type": "string", "minLength": 1, "description": "Primary string key. Used by u3a Officers, System Users, Poll assignments." },
    "mem_no":            { "type": "integer", "description": "Membership number. Used by Group members and Ledger." },
    "status":            { "type": "string", "minLength": 1, "description": "FK to Member Statuses.status by name (case-insensitive)." },
    "title":             { "type": ["string", "null"] },
    "forename":          { "type": "string", "minLength": 1 },
    "surname":           { "type": "string", "minLength": 1 },
    "suffix":            { "type": ["string", "null"] },
    "known_as":          { "type": ["string", "null"] },
    "initials":          { "type": ["string", "null"] },
    "spare":             { "type": ["string", "null"], "description": "Reserved/unused; preserve, ignore for analysis." },
    "mobile":            { "type": ["string", "null"] },
    "e-mail":            { "type": ["string", "null"], "description": "Note the hyphen in the column name." },
    "affiliation":       { "type": ["string", "null"], "description": "Home u3a if the member's primary u3a is elsewhere." },
    "custom1":           { "type": ["string", "null"] },
    "custom2":           { "type": ["string", "null"] },
    "custom3":           { "type": ["string", "null"] },
    "custom4":           { "type": ["string", "null"] },
    "joined":            { "type": ["string", "null"], "format": "date", "description": "Date member first joined." },
    "renew":             { "type": ["string", "null"], "format": "date", "description": "Next renewal due date." },
    "gift_aid":          { "type": ["string", "null"], "format": "date", "description": "Date Gift Aid declaration was signed." },
    "class":             { "type": "string", "minLength": 1, "description": "FK to Membership Classes.class by name (case-insensitive)." },
    "mem_notes":         { "type": ["string", "null"] },
    "akey":              { "type": ["string", "null"], "description": "Address group key. Members sharing this are partners." },
    "house":             { "type": ["string", "null"] },
    "address1":          { "type": ["string", "null"] },
    "address2":          { "type": ["string", "null"] },
    "address3":          { "type": ["string", "null"] },
    "town":              { "type": ["string", "null"] },
    "postcode":          { "type": ["string", "null"] },
    "county":            { "type": ["string", "null"] },
    "telephone":         { "type": ["string", "null"] },
    "add_notes":         { "type": ["string", "null"] },
    "emergency_contact": { "type": ["string", "null"] },
    "enhanced_privacy":  { "type": "boolean", "description": "If true, contact info hidden in directory." },
    "payment_type":      { "type": ["string", "null"], "description": "Default payment method for renewals." }
  }
}

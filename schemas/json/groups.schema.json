{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "beacon/groups.schema.json",
  "title": "Groups sheet row",
  "description": "Interest groups. Note that several columns are denormalised aggregates from Group members.",
  "type": "object",
  "additionalProperties": false,
  "required": ["gkey", "group_name", "status", "join_online", "leave_online", "waiting_list", "notify_leader"],
  "properties": {
    "gkey":          { "type": "string", "minLength": 1, "description": "Primary string key." },
    "group_name":    { "type": "string", "minLength": 1, "description": "Display name. FK target for Ledger.group by name." },
    "faculty":       { "type": ["string", "null"], "description": "FK to Faculties.faculty by name." },
    "venue":         { "type": ["string", "null"], "description": "Free-text venue (may not match a Venues row)." },
    "status":        { "type": "boolean", "description": "Active flag (Beacon writes 1 = active, 0 = inactive)." },
    "info":          { "type": ["string", "null"], "description": "Public description." },
    "meets_when":    { "type": ["string", "null"], "description": "Free-text frequency." },
    "start_time":    { "type": ["string", "null"], "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$" },
    "end_time":      { "type": ["string", "null"], "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$" },
    "members":       { "type": ["integer", "null"], "description": "DENORMALISED count. Recompute from Group members for accuracy." },
    "max_members":   { "type": ["integer", "null"], "description": "Capacity. Null = no cap." },
    "notes":         { "type": ["string", "null"] },
    "contact":       { "type": ["string", "null"], "description": "Free-text enquiries contact." },
    "join_online":   { "type": "boolean" },
    "leave_online":  { "type": "boolean" },
    "waiting_list":  { "type": "boolean" },
    "notify_leader": { "type": "boolean" },
    "leaders":       { "type": ["string", "null"], "description": "DENORMALISED free-text list of leader names." },
    "mkey":          { "type": ["string", "null"], "description": "DENORMALISED primary leader's mkey." },
    "mem_no":        { "type": ["integer", "null"], "description": "DENORMALISED primary leader's mem_no." },
    "leaders_count": { "type": ["integer", "null"], "description": "DENORMALISED count of leaders." },
    "gvkey":         { "type": ["string", "null"], "description": "FK to Venues.gvkey by key." },
    "gfkey":         { "type": ["string", "null"], "description": "FK to Faculties.gfkey by key (duplicate of faculty lookup)." }
  }
}
